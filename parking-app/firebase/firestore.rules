rules_version = '2';

// Regole di partenza per il progetto Firebase di ParkFree.
// Nota: il controllo di vicinanza GPS (chi può segnalare un posto) è
// applicato lato client (vedi src/data/firebaseRepository.ts). Queste regole
// non possono verificare la posizione reale del dispositivo: per bloccare
// segnalazioni "spoofate" andrebbe introdotta una Cloud Function che riceve
// solo l'id del posto e calcola la distanza usando la posizione nota al
// server (es. da un servizio di geolocalizzazione lato backend).
service cloud.firestore {
  match /databases/{database}/documents {

    // Parcheggi: lettura pubblica per chi è autenticato (anche in modo
    // anonimo). La creazione/cancellazione è riservata all'amministrazione
    // (seed manuale o Cloud Function), gli utenti possono solo aggiornare
    // lo stato di un posto esistente.
    match /parkingSpots/{spotId} {
      allow read: if request.auth != null;
      allow create, delete: if false;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'statusUpdatedAt', 'statusUpdatedBy'])
        && request.resource.data.status in ['free', 'occupied']
        && request.resource.data.statusUpdatedBy == request.auth.uid;
    }

    // Profilo utente: ogni utente vede e modifica solo il proprio documento.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /pointsHistory/{eventId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.userId == userId;
        allow update, delete: if false;
      }
    }
  }
}
