# Copia questo file in ".env" e valorizzalo con le credenziali del tuo
# progetto Firebase (Console Firebase > Impostazioni progetto > App web).
# Se lasci questo file assente o incompleto, l'app funziona comunque usando
# un backend locale sul dispositivo (utile per demo/sviluppo senza setup).

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
