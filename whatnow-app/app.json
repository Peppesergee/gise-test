{
  "expo": {
    "name": "WhatNow?",
    "slug": "whatnow",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.whatnow.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "WhatNow? usa la tua posizione per leggere il meteo del momento e darti suggerimenti più utili."
      }
    },
    "android": {
      "package": "com.whatnow.app",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "WhatNow? usa la tua posizione per leggere il meteo del momento e darti suggerimenti più utili."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "backgroundColor": "#000000",
          "resizeMode": "contain"
        }
      ]
    ]
  }
}
